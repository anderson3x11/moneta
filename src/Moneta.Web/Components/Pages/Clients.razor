@page "/clients"
@inherits ProtectedComponentBase
@inject MonetaApiClient Api

<PageTitle>Clients — Moneta</PageTitle>

<h1 class="h3 mb-3">Clients</h1>

@if (!AuthReady)
{
    <p class="text-muted">Chargement…</p>
}
else
{
    <div class="row g-4">
        <div class="col-lg-7">
            @if (_loading)
            {
                <p class="text-muted">Chargement…</p>
            }
            else if (_clients.Count == 0)
            {
                <p class="text-muted">Aucun client.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr><th>Nom</th><th>Ville</th><th>SIRET</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var client in _clients)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@client.Name</div>
                                        <div class="text-muted small">@client.Email</div>
                                    </td>
                                    <td>@client.Address.City</td>
                                    <td class="small">@(client.Siret ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h2 class="h6 mb-3">Nouveau client</h2>

                    <div class="mb-2">
                        <label class="form-label small">Nom</label>
                        <input class="form-control form-control-sm" @bind="_name" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Email</label>
                        <input class="form-control form-control-sm" @bind="_email" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">SIRET (optionnel)</label>
                        <input class="form-control form-control-sm" @bind="_siret" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Adresse</label>
                        <input class="form-control form-control-sm" @bind="_line1" />
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-4">
                            <input class="form-control form-control-sm" placeholder="Code postal" @bind="_postalCode" />
                        </div>
                        <div class="col-8">
                            <input class="form-control form-control-sm" placeholder="Ville" @bind="_city" />
                        </div>
                    </div>

                    @if (_error is not null)
                    {
                        <div class="alert alert-danger py-2 small">@_error</div>
                    }

                    <button class="btn btn-primary btn-sm w-100" @onclick="Create" disabled="@_busy">Ajouter</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<ClientResponse> _clients = [];
    private bool _loading = true;
    private bool _busy;
    private string? _error;

    private string _name = "";
    private string _email = "";
    private string _siret = "";
    private string _line1 = "";
    private string _postalCode = "";
    private string _city = "";

    protected override Task OnAuthenticatedAsync() => Load();

    private async Task Load()
    {
        _loading = true;
        _clients = await Api.GetClientsAsync();
        _loading = false;
    }

    private async Task Create()
    {
        _error = null;
        _busy = true;
        try
        {
            var request = new CreateClientRequest(
                _name,
                _email,
                new AddressDto(_line1, _postalCode, _city),
                string.IsNullOrWhiteSpace(_siret) ? null : _siret);

            var created = await Api.CreateClientAsync(request);
            if (created is null)
            {
                _error = "Vérifiez les champs (email et SIRET valides).";
                return;
            }

            _name = _email = _siret = _line1 = _postalCode = _city = "";
            await Load();
        }
        catch
        {
            _error = "Vérifiez les champs (email et SIRET valides).";
        }
        finally
        {
            _busy = false;
        }
    }
}
